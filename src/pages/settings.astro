---
import Layout from "../components/Layout.astro";
import "../db/seed";
import { listAllMeters } from "../db/meters";
import MeterSettings from "../components/MeterSettings";

const meters = listAllMeters().map((m) => ({
  id: m.id,
  name: m.name,
  rainWater: m.rain_water === 1,
  active: m.active === 1,
  sortOrder: m.sort_order,
  submeterOf: m.submeter_of,
}));
---

<Layout title="Setări">
  <h1>Setări contoare</h1>
  <MeterSettings meters={meters} client:load />
</Layout>
